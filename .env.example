# Client-safe value. Only variables prefixed with NEXT_PUBLIC_ are bundled for browsers.
NEXT_PUBLIC_APP_ENV=development

# Supabase browser-safe project configuration (required for authentication).
# Use the publishable key, never a service_role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only optional integrations.
# Never prefix secrets with NEXT_PUBLIC_ and never commit real credentials.
# Used only on the server for Thai Company Profile translation.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
# Server-only provider for quotes, profile, OHLCV, and Phase 10.4 financial statements.
# Fundamentals use INCOME_STATEMENT, BALANCE_SHEET, and CASH_FLOW endpoints.
ALPHA_VANTAGE_API_KEY=
# Server-only secondary Company Profile JSON provider used after retryable Alpha Vantage failures.
FMP_API_KEY=
# Primary production provider for stock quote, OHLCV, and exchange session data.
# MARKET_DATA_PROVIDER currently accepts only "polygon" when configured.
POLYGON_API_KEY=
MARKET_DATA_PROVIDER=polygon
# Server-only NewsAPI credential. Configure this exact name in each Vercel
# environment that should serve /api/news; market-data keys are not reused.
NEWS_API_KEY=

# --- Phase 12: Alpaca real-time market stream (server-only) ---
# The browser NEVER connects to Alpaca directly and NEVER sees these keys. They
# are read only by the standalone Node WebSocket Gateway service. Never prefix
# them with NEXT_PUBLIC_ and never commit real credentials.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
# Feed: iex (Alpaca Basic, default), sip (paid entitlement), or test (FAKEPACA sandbox).
ALPACA_DATA_FEED=iex
# Master switch for the Gateway. When false or unset, the app stays on REST polling.
MARKET_REALTIME_ENABLED=false
# Client-safe URL of the deployed Gateway service the browser subscribes to,
# e.g. wss://market-gateway.example.com/ws. This is NOT a secret. Leave blank to
# keep the browser on REST polling. Serverless/Vercel route handlers cannot host
# this persistent socket — deploy the Gateway as its own long-lived Node service.
# Set this in Vercel (Production) so the middleware CSP allows the wss:// origin.
NEXT_PUBLIC_MARKET_WS_URL=
# --- Gateway host only (Railway) + local dev, NOT Vercel ---
# Comma-separated browser origins allowed to open the Gateway /ws endpoint, e.g.
# https://app.example.com,https://staging.example.com. Required in production.
# Also required for LOCAL dev: `npm run gateway` runs with NODE_ENV unset (not
# "development"), so localhost is NOT auto-allowed — set the Next dev origin here
# (default http://localhost:3000) or the browser handshake is rejected with 403.
# Not a secret.
NEXORA_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Gateway listen port for local/dev. In production the platform injects PORT,
# which takes precedence over this value. Not a secret.
MARKET_WS_PORT=8081
# Server-only admin key used by instrument sync and the server-side persistent FX cache. Never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Shared bearer token used only by the scheduler and /api/cron/alerts.
CRON_SECRET=
# Generate once with: npx web-push generate-vapid-keys
# The public key is returned by an authenticated server endpoint; the private key never leaves the server.
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:ops@example.com
APP_URL=

# Server-side analytics feature flags. Fair Value defaults to enabled; set it to
# false only when an operational rollback is required. Other features remain
# hidden unless explicitly enabled.
FEATURE_TECHNICAL_INDICATORS=false
FEATURE_ADVANCED_CHART_TYPES=false
FEATURE_EXTENDED_INDICATORS=false
FEATURE_SUPPORT_RESISTANCE=false
FEATURE_KEY_STATISTICS=false
FEATURE_OPTIONS_STATISTICS=false
FEATURE_ANALYST_CONSENSUS=false
FEATURE_FAIR_VALUE=true
