# Client-safe value. Only variables prefixed with NEXT_PUBLIC_ are bundled for browsers.
NEXT_PUBLIC_APP_ENV=development

# Supabase browser-safe project configuration (required for authentication).
# Use the publishable key, never a service_role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only optional integrations.
# Never prefix secrets with NEXT_PUBLIC_ and never commit real credentials.
# Used only on the server for Thai Company Profile translation.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
# Server-only provider for quotes, profile, OHLCV, and Phase 10.4 financial statements.
# Fundamentals use INCOME_STATEMENT, BALANCE_SHEET, and CASH_FLOW endpoints.
ALPHA_VANTAGE_API_KEY=
# Server-only secondary Company Profile JSON provider used after retryable Alpha Vantage failures.
FMP_API_KEY=
# Server-only NewsAPI credential. Configure this exact name in each Vercel
# environment that should serve /api/news; market-data keys are not reused.
NEWS_API_KEY=
# Server-only admin key used by instrument sync and the server-side persistent FX cache. Never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Shared bearer token used only by the scheduler and /api/cron/alerts.
CRON_SECRET=
# Generate once with: npx web-push generate-vapid-keys
# The public key is returned by an authenticated server endpoint; the private key never leaves the server.
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:ops@example.com
APP_URL=

# Server-side analytics feature flags. Fair Value defaults to enabled; set it to
# false only when an operational rollback is required. Other features remain
# hidden unless explicitly enabled.
FEATURE_TECHNICAL_INDICATORS=false
FEATURE_ADVANCED_CHART_TYPES=false
FEATURE_EXTENDED_INDICATORS=false
FEATURE_SUPPORT_RESISTANCE=false
FEATURE_KEY_STATISTICS=false
FEATURE_OPTIONS_STATISTICS=false
FEATURE_ANALYST_CONSENSUS=false
FEATURE_FAIR_VALUE=true
