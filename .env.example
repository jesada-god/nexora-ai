# Client-safe value. Only variables prefixed with NEXT_PUBLIC_ are bundled for browsers.
NEXT_PUBLIC_APP_ENV=development

# Supabase browser-safe project configuration (required for authentication).
# Use the publishable key, never a service_role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only optional integrations.
# Never prefix secrets with NEXT_PUBLIC_ and never commit real credentials.
GEMINI_API_KEY=
ALPHA_VANTAGE_API_KEY=
NEWS_API_KEY=
# Server-only admin key used by instrument sync and the server-side persistent FX cache. Never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Shared bearer token used only by the scheduler and /api/cron/alerts.
CRON_SECRET=
# Generate once with: npx web-push generate-vapid-keys
# The public key is returned by an authenticated server endpoint; the private key never leaves the server.
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:ops@example.com
APP_URL=

# Server-side analytics feature flags. Features remain hidden unless explicitly enabled.
FEATURE_TECHNICAL_INDICATORS=false
