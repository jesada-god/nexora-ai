{
  "sourceProject": "option-tool-invest-bigdata-main",
  "targetProject": "Nexora AI",
  "analyzedAt": "2026-07-24",
  "sourceRuntime": {
    "backend": "Python 3.11 / FastAPI",
    "frontend": "Single index.html with vanilla JavaScript",
    "marketProvider": "yfinance",
    "persistence": "none; process memory only"
  },
  "targetRuntime": {
    "application": "Next.js 15 / React 19 / TypeScript",
    "persistence": "Supabase",
    "marketData": "provider abstractions plus market gateway"
  },
  "features": [
    {
