    },
    {
      "id": "support-resistance",
      "source": ["main.py:calculate_pivot_levels", "main.py:get_atr_for_timeframe", "main.py:get_indicators"],
      "target": ["src/lib/analytics/support-resistance", "src/lib/analytics/decision-panel"],
      "decision": "use-target-and-add-parity-fixtures",
      "reason": "Target already owns chart decision levels."
    },
    {
      "id": "option-pricing",
