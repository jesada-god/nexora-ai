      "source": ["main.py:get_market_session", "main.py:get_price_bundle", "main.py:get_chart_data", "main.py:websocket_endpoint"],
      "target": ["src/lib/market-data", "services/market-gateway"],
      "decision": "use-target",
      "reason": "Target already has provider contracts, realtime protocol, caching and tests."
    },
    {
      "id": "watchlist",
      "source": ["main.py:get_watchlist", "main.py:add_to_watchlist", "main.py:remove_from_watchlist"],
      "target": ["src/lib/watchlist", "app/watchlist/actions.ts"],
      "decision": "use-target",
      "reason": "Target persistence and RLS replace process-global lists."
    },
    {
      "id": "fair-value",
      "source": ["main.py:calculate_fair_value"],
      "target": ["src/lib/analytics/valuation", "app/api/analytics/fair-value/[symbol]/route.ts"],
      "decision": "use-target",
      "reason": "Target has a validated and provider-aware valuation engine."
    },
    {
