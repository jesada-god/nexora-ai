      "target": ["src/lib/options-simulator", "src/workers/optionsMonteCarlo.worker.ts"],
      "decision": "use-target-and-add-parity-fixtures",
      "reason": "Target has auditable path sets, multi-leg payoff and richer risk metrics."
    },
    {
